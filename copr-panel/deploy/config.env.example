# ── copr-panel 部署参数(复制为 config.env 后按需改)────────────────────────
# 复用:换服务器/域名只改这里,install.sh 全靠这些变量,不写死任何值。

DOMAIN=copr.site                        # 对外域名(订阅 + 面板)

# 面板(静态 Vue,nginx 直出)
PANEL_DIR=/opt/copr-panel/web           # dist 落地目录
PANEL_PATH=/panel/                       # nginx 访问路径 → https://DOMAIN/panel/
PANEL_USER=admin                         # 面板 HTTP 基础认证账号(护住 /panel/,含 conv admin)
PANEL_PASS=change-me-panel-password      # ⚠️ 换强密码

# s-ui 面板 API(cookie 同源反代,免 CORS)
SUI_ADDR=127.0.0.1:2020                  # s-ui 监听
SUI_BASE=/app/                            # s-ui 面板 base path

# onetapclash 壳层(converter)
CONV_DIR=/opt/sui-converter              # 现有目录,保留 users.json / rules.json
CONV_ADDR=127.0.0.1:25501
CONV_ADMIN_SECRET=change-me-to-a-long-random-string   # ⚠️ 换强密钥(旧的太弱)

# TLS(可选;留空=仅 HTTP。填证书路径则加 443)
TLS_CERT=/etc/letsencrypt/live/copr.site/fullchain.pem
TLS_KEY=/etc/letsencrypt/live/copr.site/privkey.pem

# 远程(push.sh 用)
SSH_HOST=root@212.135.210.101
SSH_KEY=                                  # 留空用默认 ~/.ssh;或指定私钥路径

# ── bootstrap.sh 专用(一键装 s-ui + 域名硬化 hy2 + converter)──────────────
CERT_MODE=le                             # le=Let's Encrypt(webroot) / self=自备证书
SUI_SUB_BASE=http://127.0.0.1:2096/sub/  # s-ui 原生订阅前缀(converter 抓每个用户的上游订阅)
HY2_TAG=快速节点                          # 要域名硬化的 s-ui hy2 入站 tag

# 域名硬化自动化(选填;填了则脚本经 s-ui API 应用证书,否则打印面板步骤)
SUI_API=                                 # 例 http://127.0.0.1:9000/app/  留空=手动
SUI_USER=                                # s-ui 管理员账号
SUI_PASS=                                # s-ui 管理员密码
